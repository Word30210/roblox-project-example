{
    "name": "main",
    "tree": {
        "$className": "DataModel",
        "ReplicatedStorage": {
            "roblox_packages": { "$path": { "optional": "roblox_packages" } },
            "remotes": { "$path": "rojo-assets/shared/remotes" }
        },
        "ServerScriptService": { "$path": { "optional": "dist/server" } },
        "ServerStorage": {
            "storage": { "$path": { "optional": "dist/storage" } }
        },
        "StarterPlayer": {
            "StarterPlayerScripts": { "$path": { "optional": "dist/client" } }
        },
        "Workspace": { "$path": { "optional": "dist/workspace" } },
        "Players": {
            "$properties": { "CharacterAutoLoads": false }
        },
        "TextChatService": {
            "TextChatCommands": { "$path": "rojo-assets/shared/commands" }
        }
    }
}